{
  "version": 1,
  "updated": "2026-06-29",
  "id": "kubernetes",
  "name": "Kubernetes",
  "binary": "kubectl",
  "sourceCategory": "Kubernetes",
  "description": "Kubernetes command pack generated from the console's Kubernetes command catalog.",
  "commands": [
    {
      "id": "kubectl_config_current_context",
      "name": "kubectl current context",
      "description": "Show the active Kubernetes context.",
      "command": [
        "kubectl",
        "config",
        "current-context"
      ],
      "subcommand": [
        "config",
        "current-context"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "kubectl_get_pods",
      "name": "kubectl get pods",
      "description": "List Kubernetes pods in a namespace.",
      "command": [
        "kubectl",
        "get",
        "pods",
        "-n",
        "{namespace}"
      ],
      "subcommand": [
        "get",
        "pods",
        "-n",
        "{namespace}"
      ],
      "defaults": {
        "namespace": "default"
      },
      "mutates": false
    },
    {
      "id": "kubectl_get_deployments",
      "name": "kubectl get deployments",
      "description": "List Kubernetes deployments in a namespace.",
      "command": [
        "kubectl",
        "get",
        "deployments",
        "-n",
        "{namespace}"
      ],
      "subcommand": [
        "get",
        "deployments",
        "-n",
        "{namespace}"
      ],
      "defaults": {
        "namespace": "default"
      },
      "mutates": false
    },
    {
      "id": "kubectl_describe_pod",
      "name": "kubectl describe pod",
      "description": "Describe a Kubernetes pod.",
      "command": [
        "kubectl",
        "describe",
        "pod",
        "{pod}",
        "-n",
        "{namespace}"
      ],
      "subcommand": [
        "describe",
        "pod",
        "{pod}",
        "-n",
        "{namespace}"
      ],
      "defaults": {
        "pod": "pod-name",
        "namespace": "default"
      },
      "mutates": false
    },
    {
      "id": "kubectl_logs",
      "name": "kubectl logs",
      "description": "Read recent logs from a Kubernetes pod.",
      "command": [
        "kubectl",
        "logs",
        "{pod}",
        "-n",
        "{namespace}",
        "--tail",
        "{tail}"
      ],
      "subcommand": [
        "logs",
        "{pod}",
        "-n",
        "{namespace}",
        "--tail",
        "{tail}"
      ],
      "defaults": {
        "pod": "pod-name",
        "namespace": "default",
        "tail": "200"
