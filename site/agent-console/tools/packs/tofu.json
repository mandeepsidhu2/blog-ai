{
  "version": 1,
  "updated": "2026-06-29",
  "id": "tofu",
  "name": "Tofu",
  "binary": "tofu",
  "sourceCategory": "Terraform",
  "description": "Tofu command pack generated from the console's Terraform command catalog.",
  "commands": [
    {
      "id": "tofu_init",
      "name": "Tofu init",
      "description": "Initialize Tofu providers and backend metadata.",
      "command": [
        "tofu",
        "init"
      ],
      "subcommand": [
        "init"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "tofu_fmt_check",
      "name": "Tofu fmt check",
      "description": "Check Tofu formatting recursively without rewriting files.",
      "command": [
        "tofu",
        "fmt",
        "-check",
        "-recursive"
      ],
      "subcommand": [
        "fmt",
        "-check",
        "-recursive"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_validate",
      "name": "Tofu validate",
      "description": "Validate Tofu configuration syntax and provider schemas.",
      "command": [
        "tofu",
        "validate"
      ],
      "subcommand": [
        "validate"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_plan",
      "name": "Tofu plan",
      "description": "Create a Tofu execution plan.",
      "command": [
        "tofu",
        "plan",
        "-out",
        "{plan_file}"
      ],
      "subcommand": [
        "plan",
        "-out",
        "{plan_file}"
      ],
      "defaults": {
        "plan_file": "tfplan"
      },
      "mutates": false
    },
    {
      "id": "tofu_apply",
      "name": "Tofu apply",
      "description": "Apply a saved Tofu execution plan.",
      "command": [
        "tofu",
        "apply",
        "{plan_file}"
      ],
      "subcommand": [
        "apply",
        "{plan_file}"
      ],
      "defaults": {
        "plan_file": "tfplan"
      },
      "mutates": true
    },
    {
      "id": "tofu_state_list",
      "name": "Tofu state list",
      "description": "List resources in Tofu state.",
      "command": [
        "tofu",
        "state",
        "list"
      ],
      "subcommand": [
        "state",
        "list"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_output",
      "name": "Tofu output",
      "description": "Read Tofu outputs as JSON.",
      "command": [
        "tofu",
        "output",
        "-json"
      ],
      "subcommand": [
        "output",
        "-json"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_show_plan",
      "name": "Tofu show plan JSON",
      "description": "Render a saved Tofu plan as JSON for AI inspection.",
      "command": [
        "tofu",
        "show",
        "-json",
        "{plan_file}"
      ],
      "subcommand": [
        "show",
        "-json",
        "{plan_file}"
      ],
      "defaults": {
        "plan_file": "tfplan"
      },
      "mutates": false
    },
    {
      "id": "tofu_workspace_list",
      "name": "Tofu workspace list",
      "description": "List Tofu workspaces.",
      "command": [
        "tofu",
        "workspace",
        "list"
      ],
      "subcommand": [
        "workspace",
        "list"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_workspace_select",
      "name": "Tofu workspace select",
      "description": "Select an existing Tofu workspace.",
      "command": [
        "tofu",
        "workspace",
        "select",
        "{workspace}"
      ],
      "subcommand": [
        "workspace",
        "select",
        "{workspace}"
      ],
      "defaults": {
        "workspace": "default"
      },
      "mutates": true
    },
    {
      "id": "tofu_workspace_new",
      "name": "Tofu workspace new",
      "description": "Create and select a Tofu workspace.",
      "command": [
        "tofu",
        "workspace",
        "new",
        "{workspace}"
      ],
      "subcommand": [
        "workspace",
        "new",
        "{workspace}"
      ],
      "defaults": {
        "workspace": "feature"
      },
      "mutates": true
    },
    {
      "id": "tofu_import",
      "name": "Tofu import",
      "description": "Import an existing remote object into Tofu state.",
      "command": [
        "tofu",
        "import",
        "{address}",
        "{resource_id}"
      ],
      "subcommand": [
        "import",
        "{address}",
        "{resource_id}"
      ],
      "defaults": {
        "address": "aws_s3_bucket.example",
        "resource_id": "bucket-name"
      },
      "mutates": true
    },
    {
      "id": "tofu_state_show",
      "name": "Tofu state show",
      "description": "Show attributes for a resource in Tofu state.",
      "command": [
        "tofu",
        "state",
        "show",
        "{address}"
      ],
      "subcommand": [
        "state",
        "show",
        "{address}"
      ],
      "defaults": {
        "address": "aws_s3_bucket.example"
      },
      "mutates": false
    },
    {
      "id": "tofu_state_rm",
      "name": "Tofu state rm",
      "description": "Remove a resource binding from Tofu state.",
      "command": [
        "tofu",
        "state",
        "rm",
        "{address}"
      ],
      "subcommand": [
        "state",
        "rm",
        "{address}"
      ],
      "defaults": {
        "address": "aws_s3_bucket.example"
      },
      "mutates": true
    },
    {
      "id": "tofu_providers_lock",
      "name": "Tofu providers lock",
      "description": "Write provider dependency locks for the current platform.",
      "command": [
        "tofu",
        "providers",
        "lock"
      ],
      "subcommand": [
        "providers",
        "lock"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "tofu_graph",
      "name": "Tofu graph",
      "description": "Emit the Tofu dependency graph in DOT format.",
      "command": [
        "tofu",
        "graph"
      ],
      "subcommand": [
        "graph"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_test",
      "name": "Tofu test",
      "description": "Run Tofu native tests for modules in the current configuration.",
      "command": [
        "tofu",
        "test"
      ],
      "subcommand": [
        "test"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_version",
      "name": "Tofu version",
      "description": "Show the Tofu CLI version.",
      "command": [
        "tofu",
        "version"
      ],
      "subcommand": [
        "version"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "tofu_destroy",
      "name": "Tofu destroy",
      "description": "Destroy Tofu-managed infrastructure after explicit approval.",
      "command": [
        "tofu",
        "destroy",
        "-auto-approve"
      ],
      "subcommand": [
        "destroy",
        "-auto-approve"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "tofu_force_unlock",
      "name": "Tofu force unlock",
      "description": "Force-unlock a stuck Tofu state lock after explicit approval.",
      "command": [
        "tofu",
        "force-unlock",
        "-force",
        "{lock_id}"
      ],
      "subcommand": [
        "force-unlock",
        "-force",
        "{lock_id}"
      ],
      "defaults": {
        "lock_id": "LOCK_ID"
      },
      "mutates": true
    }
  ]
}
