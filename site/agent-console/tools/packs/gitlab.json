{
  "version": 1,
  "updated": "2026-06-29",
  "id": "gitlab",
  "name": "GitLab",
  "binary": "glab",
  "sourceCategory": "GitLab",
  "description": "GitLab command pack generated from the console's GitLab command catalog.",
  "commands": [
    {
      "id": "gitlab_repo_view",
      "name": "GitLab repo view",
      "description": "Inspect project metadata with the GitLab CLI.",
      "command": [
        "glab",
        "repo",
        "view"
      ],
      "subcommand": [
        "repo",
        "view"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "gitlab_mr_list",
      "name": "GitLab MR list",
      "description": "List GitLab merge requests by state.",
      "command": [
        "glab",
        "mr",
        "list",
        "--state",
        "{state}"
      ],
      "subcommand": [
        "mr",
        "list",
        "--state",
        "{state}"
      ],
      "defaults": {
        "state": "opened"
      },
      "mutates": false
    },
    {
      "id": "gitlab_mr_create",
      "name": "GitLab MR create",
      "description": "Create a GitLab merge request from the current branch.",
      "command": [
        "glab",
        "mr",
        "create",
        "--title",
        "{title}",
        "--description",
        "{description}"
      ],
      "subcommand": [
        "mr",
        "create",
        "--title",
        "{title}",
        "--description",
        "{description}"
      ],
      "defaults": {
        "title": "Agent workflow update",
        "description": "Generated by the LangGraph agent console."
      },
      "mutates": true
    },
    {
      "id": "gitlab_pipeline_list",
      "name": "GitLab pipeline list",
      "description": "List recent GitLab CI pipelines.",
      "command": [
        "glab",
        "pipeline",
        "list"
      ],
      "subcommand": [
        "pipeline",
        "list"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "gitlab_issue_list",
      "name": "GitLab issue list",
      "description": "List GitLab issues by state.",
      "command": [
        "glab",
        "issue",
        "list",
        "--state",
        "{state}"
      ],
      "subcommand": [
        "issue",
        "list",
        "--state",
        "{state}"
      ],
      "defaults": {
        "state": "opened"
      },
      "mutates": false
    },
    {
      "id": "gitlab_release_create",
      "name": "GitLab release create",
      "description": "Create a GitLab release for an existing tag.",
      "command": [
        "glab",
        "release",
        "create",
        "{tag}",
        "--name",
        "{name}",
        "--notes",
        "{notes}"
      ],
      "subcommand": [
        "release",
        "create",
        "{tag}",
        "--name",
        "{name}",
        "--notes",
        "{notes}"
      ],
      "defaults": {
        "tag": "v0.1.0",
        "name": "v0.1.0",
        "notes": "Release generated by the LangGraph agent console."
      },
      "mutates": true
    }
  ]
}
