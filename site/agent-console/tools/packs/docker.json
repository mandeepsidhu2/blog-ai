{
  "version": 1,
  "updated": "2026-06-29",
  "id": "docker",
  "name": "Docker",
  "binary": "docker",
  "sourceCategory": "Docker",
  "description": "Docker command pack generated from the console's Docker command catalog.",
  "commands": [
    {
      "id": "docker_ps",
      "name": "Docker ps",
      "description": "List Docker containers.",
      "command": [
        "docker",
        "ps",
        "--format",
        "json"
      ],
      "subcommand": [
        "ps",
        "--format",
        "json"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "docker_build",
      "name": "Docker build",
      "description": "Build a Docker image from a Dockerfile context.",
      "command": [
        "docker",
        "build",
        "-t",
        "{tag}",
        "{context}"
      ],
      "subcommand": [
        "build",
        "-t",
        "{tag}",
        "{context}"
      ],
      "defaults": {
        "tag": "agent-image:latest",
        "context": "."
      },
      "mutates": true
    },
    {
      "id": "docker_run",
      "name": "Docker run",
      "description": "Run a Docker image with a container name.",
      "command": [
        "docker",
        "run",
        "--rm",
        "--name",
        "{name}",
        "{image}"
      ],
      "subcommand": [
        "run",
        "--rm",
        "--name",
        "{name}",
        "{image}"
      ],
      "defaults": {
        "name": "agent-run",
        "image": "agent-image:latest"
      },
      "mutates": true
    },
    {
      "id": "docker_logs",
      "name": "Docker logs",
      "description": "Read recent logs from a Docker container.",
      "command": [
        "docker",
        "logs",
        "--tail",
        "{tail}",
        "{container}"
      ],
      "subcommand": [
        "logs",
        "--tail",
        "{tail}",
        "{container}"
      ],
      "defaults": {
        "tail": "200",
        "container": "container-name"
      },
      "mutates": false
    },
    {
      "id": "docker_compose_up",
      "name": "Docker Compose up",
      "description": "Start Docker Compose services in detached mode.",
      "command": [
        "docker",
        "compose",
        "up",
        "-d"
      ],
      "subcommand": [
        "compose",
        "up",
        "-d"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "docker_compose_down",
      "name": "Docker Compose down",
      "description": "Stop Docker Compose services.",
      "command": [
        "docker",
        "compose",
        "down"
      ],
      "subcommand": [
        "compose",
        "down"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "docker_exec",
      "name": "Docker exec",
      "description": "Run a command in a running Docker container.",
      "command": [
        "docker",
        "exec",
        "{container}",
        "{command}"
      ],
      "subcommand": [
        "exec",
        "{container}",
        "{command}"
      ],
      "defaults": {
        "container": "container-name",
        "command": "sh"
      },
      "mutates": true
    },
    {
      "id": "docker_image_prune",
      "name": "Docker image prune",
      "description": "Prune dangling Docker images.",
      "command": [
        "docker",
        "image",
        "prune",
        "-f"
      ],
      "subcommand": [
        "image",
        "prune",
        "-f"
      ],
      "defaults": {},
      "mutates": true
    }
  ]
}
