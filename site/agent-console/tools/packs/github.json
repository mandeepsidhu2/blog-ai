        "gh",
        "repo",
        "view",
        "--json",
        "name,owner,description,visibility"
      ],
      "subcommand": [
        "repo",
        "view",
        "--json",
        "name,owner,description,visibility"
      ],
      "defaults": {},
      "mutates": false
    },
