      "name": "GitHub PR list",
      "description": "List open pull requests for a repository.",
      "command": [
        "gh",
        "pr",
        "list",
        "--state",
        "{state}",
        "--limit",
        "{limit}"
      ],
      "subcommand": [
        "pr",
        "list",
        "--state",
        "{state}",
        "--limit",
        "{limit}"
      ],
      "defaults": {
