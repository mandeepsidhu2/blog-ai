{
  "version": 1,
  "updated": "2026-06-29",
  "id": "npm",
  "name": "NPM",
  "binary": "npm",
  "sourceCategory": "NPM",
  "description": "NPM command pack generated from the console's NPM command catalog.",
  "commands": [
    {
      "id": "npm_install",
      "name": "npm install",
      "description": "Install package dependencies and update lock files when needed.",
      "command": [
        "npm",
        "install"
      ],
      "subcommand": [
        "install"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "npm_ci",
      "name": "npm ci",
      "description": "Install dependencies from package-lock.json for repeatable builds.",
      "command": [
        "npm",
        "ci"
      ],
      "subcommand": [
        "ci"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "npm_test",
      "name": "npm test",
      "description": "Run the project test script.",
      "command": [
        "npm",
        "test"
      ],
      "subcommand": [
        "test"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "npm_run_build",
      "name": "npm run build",
      "description": "Run the project build script.",
      "command": [
        "npm",
        "run",
        "build"
      ],
      "subcommand": [
        "run",
        "build"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "npm_run_lint",
      "name": "npm run lint",
      "description": "Run the project lint script.",
      "command": [
        "npm",
        "run",
        "lint"
      ],
      "subcommand": [
        "run",
        "lint"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "npm_audit",
      "name": "npm audit",
      "description": "Audit installed dependencies for known vulnerabilities.",
      "command": [
        "npm",
        "audit",
        "--audit-level",
        "{level}"
      ],
      "subcommand": [
        "audit",
        "--audit-level",
        "{level}"
      ],
      "defaults": {
        "level": "moderate"
      },
      "mutates": false
    },
    {
      "id": "npm_publish",
      "name": "npm publish",
      "description": "Publish the current package to the configured npm registry.",
      "command": [
        "npm",
        "publish",
        "--access",
        "{access}"
      ],
      "subcommand": [
        "publish",
        "--access",
        "{access}"
      ],
      "defaults": {
        "access": "public"
      },
      "mutates": true
    },
    {
      "id": "npm_view_package",
      "name": "npm view package",
      "description": "Read npm package metadata from the configured registry.",
      "command": [
        "npm",
        "view",
        "{package}",
        "version,dist-tags,description"
      ],
      "subcommand": [
        "view",
        "{package}",
        "version,dist-tags,description"
      ],
      "defaults": {
        "package": "."
      },
      "mutates": false
    },
    {
      "id": "npm_outdated",
      "name": "npm outdated",
      "description": "Show outdated npm dependencies.",
      "command": [
        "npm",
        "outdated",
        "--json"
      ],
      "subcommand": [
        "outdated",
        "--json"
      ],
      "defaults": {},
      "mutates": false
    },
    {
      "id": "npm_pack",
      "name": "npm pack",
      "description": "Create a tarball from the current npm package.",
      "command": [
        "npm",
        "pack"
      ],
      "subcommand": [
        "pack"
      ],
      "defaults": {},
      "mutates": true
    },
    {
      "id": "npm_run_script",
      "name": "npm run script",
      "description": "Run a named npm script.",
      "command": [
        "npm",
        "run",
        "{script}"
      ],
      "subcommand": [
        "run",
        "{script}"
      ],
      "defaults": {
        "script": "start"
      },
      "mutates": false
    }
  ]
}
